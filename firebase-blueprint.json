{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "points": { "type": "number" },
        "role": { "type": "string", "enum": ["ADMIN", "CURATOR", "USER"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "username", "points", "role", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A social media engagement task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "platform": { "type": "string", "enum": ["Instagram", "TikTok"] },
        "title": { "type": "string" },
        "instructions": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "date", "time", "platform", "title", "instructions", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A user's submission for a task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "link": { "type": "string" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "submittedAt": { "type": "string" }
      },
      "required": ["id", "taskId", "userId", "userName", "link", "likes", "comments", "submittedAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A user's activity log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "type": { "type": "string", "enum": ["DOWNLOAD_VIDEO", "SUBMIT_LINK"] },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "taskId", "type", "timestamp"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A user's reminder for a task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "userId": { "type": "string" },
        "remindAt": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "taskId", "userId", "remindAt", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Tasks available for users"
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/Submission" },
      "description": "Submissions made by users"
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Activity logs for users"
    },
    "/reminders/{reminderId}": {
      "schema": { "$ref": "#/entities/Reminder" },
      "description": "Reminders set by users"
    }
  }
}
